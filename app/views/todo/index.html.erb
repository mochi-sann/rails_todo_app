<h1><%= t "todoHeading"%></h1>
<div>
  <%= link_to "New todo", new_todo_path if authenticated? %>
</div>
<h1><%= t "app.index.todoList" %></h1>
<div>
  <ul>
    <% @todos.each do |todo| %>
      <li>
        <a href="/todo/<%= todo.id %>"><%= todo.title %>
      </a>
    </li>
    <% end %>
  </ul>
</div>

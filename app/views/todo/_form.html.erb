<%= form_with model: todo, url: todo_index_path do |form| %>
  <div>
    <%= form.label :title %>
    <%= form.text_field :title %>
    <% if todo.errors[:title].any? %>
        <div style="color: red;">
          <%= todo.errors[:title].first %>
        </div>
    <% end %>
    </br>
    <%= form.label :done %>
    <%= form.check_box :done %>
    <div>
      <%= form.label :featured_image, style: "display: block" %>
      <%= form.file_field :featured_image, accept: "image/*" %>
    </div>

  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>


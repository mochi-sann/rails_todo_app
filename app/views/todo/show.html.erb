<h1>this is html </h1>
<div id="task">

  <p>
  <%= @todo.title %>
  </p>
  <%= check_box_tag 'task[done]', '1', @todo.done? %>
</div>
<%= link_to "Back", root_path %>
<%= link_to "Edit", edit_todo_path(@todo) %>
<%= button_to "Delete", @todo, method: :delete, data: { turbo_confirm: "Are you sure?"} %>
